@import "tailwindcss";
@plugin "@tailwindcss/typography";

@theme {
  --font-sans: var(--font-inter), "Inter", system-ui, -apple-system, sans-serif;
  --font-mono: var(--font-mono), "JetBrains Mono", monospace;

  --color-border: hsl(var(--border));
  --color-input: hsl(var(--input));
  --color-ring: hsl(var(--ring));
  --color-background: hsl(var(--background));
  --color-foreground: hsl(var(--foreground));

  --color-primary: hsl(var(--primary));
  --color-primary-foreground: hsl(var(--primary-foreground));

  --color-secondary: hsl(var(--secondary));
  --color-secondary-foreground: hsl(var(--secondary-foreground));

  --color-destructive: hsl(var(--destructive));
  --color-destructive-foreground: hsl(var(--destructive-foreground));

  --color-muted: hsl(var(--muted));
  --color-muted-foreground: hsl(var(--muted-foreground));

  --color-accent: hsl(var(--accent));
  --color-accent-foreground: hsl(var(--accent-foreground));

  --color-popover: hsl(var(--popover));
  --color-popover-foreground: hsl(var(--popover-foreground));

  --color-card: hsl(var(--card));
  --color-card-foreground: hsl(var(--card-foreground));

  --radius-lg: var(--radius);
  --radius-md: calc(var(--radius) - 2px);
  --radius-sm: calc(var(--radius) - 4px);
}

@layer base {
  :root {
    /* LIGHT PASTEL GLASS UI THEME */
    --background: 210 40% 98%; /* Very light blue/gray base */
    --foreground: 222 47% 11%; /* Dark slate for high readability */
    
    /* Highly transparent white for glass effect */
    --card: 0 0% 100%; 
    --card-foreground: 222 47% 11%;
    
    --popover: 0 0% 100%;
    --popover-foreground: 222 47% 11%;
    
    --primary: 262 83% 58%; /* Vibrant pastel purple */
    --primary-foreground: 0 0% 100%; /* White text on primary */
    
    --secondary: 210 40% 96.1%;
    --secondary-foreground: 222.2 47.4% 11.2%;
    
    --muted: 210 40% 96.1%;
    --muted-foreground: 215.4 16.3% 46.9%;
    
    --accent: 210 40% 96.1%;
    --accent-foreground: 222.2 47.4% 11.2%;
    
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 210 40% 98%;
    
    --border: 214.3 31.8% 91.4%;
    --input: 214.3 31.8% 91.4%;
    --ring: 262 83% 58%; /* Purple ring */
    
    --radius: 1rem; /* More rounded corners for premium feel */

    /* Semantic Colors - Light */
    --color-success-bg: 142 71% 95%;
    --color-success-text: 142 76% 36%;
    --color-warning-bg: 38 92% 95%;
    --color-warning-text: 38 92% 40%;
    --color-error-bg: 0 84% 95%;
    --color-error-text: 0 84% 45%;
    --color-info-bg: 199 89% 95%;
    --color-info-text: 199 89% 45%;
  }

  .dark {
    /* Map everything to light theme. We are disabling dark mode to force the Light Pastel UI */
    --background: 210 40% 98%;
    --foreground: 222 47% 11%;
    --card: 0 0% 100%;
    --card-foreground: 222 47% 11%;
    --popover: 0 0% 100%;
    --popover-foreground: 222 47% 11%;
    --primary: 262 83% 58%;
    --primary-foreground: 0 0% 100%;
    --secondary: 210 40% 96.1%;
    --secondary-foreground: 222.2 47.4% 11.2%;
    --muted: 210 40% 96.1%;
    --muted-foreground: 215.4 16.3% 46.9%;
    --accent: 210 40% 96.1%;
    --accent-foreground: 222.2 47.4% 11.2%;
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 210 40% 98%;
    --border: 214.3 31.8% 91.4%;
    --input: 214.3 31.8% 91.4%;
    --ring: 262 83% 58%;
  }
}

@layer base {
  * {
    @apply border-border;
    border-color: hsl(var(--border) / 0.5); /* Soft transparent borders */
  }
  body {
    @apply bg-background text-foreground;
  }
}

/* ============================================
   LIGHT PASTEL GLASS UI OVERRIDES
   ============================================ */

/* 1. Animated Gradient Mesh Background */
.bg-gradient-mesh {
  background: radial-gradient(at 0% 0%, hsla(253,16%,7%,0) 0, transparent 50%), 
              radial-gradient(at 50% 0%, hsla(225,39%,30%,0) 0, transparent 50%), 
              radial-gradient(at 100% 0%, hsla(339,49%,30%,0) 0, transparent 50%);
  background-color: #f1f5f9;
  background-image: 
    radial-gradient(at 40% 20%, hsla(262, 83%, 90%, 1) 0px, transparent 50%),
    radial-gradient(at 80% 0%, hsla(189, 100%, 85%, 1) 0px, transparent 50%),
    radial-gradient(at 0% 50%, hsla(330, 100%, 89%, 1) 0px, transparent 50%),
    radial-gradient(at 80% 50%, hsla(260, 100%, 85%, 1) 0px, transparent 50%),
    radial-gradient(at 0% 100%, hsla(22, 100%, 87%, 1) 0px, transparent 50%),
    radial-gradient(at 80% 100%, hsla(242, 100%, 85%, 1) 0px, transparent 50%),
    radial-gradient(at 0% 0%, hsla(343, 100%, 86%, 1) 0px, transparent 50%);
  filter: blur(40px);
  z-index: 0;
  opacity: 0.8 !important; /* Override layout opacity */
}

/* 2. Glass Morphism Panels */
.glass {
  @apply bg-white/40 backdrop-blur-xl border border-white/60;
  box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
}

.glass-card {
  @apply bg-white/60 backdrop-blur-md border border-white/50;
  box-shadow: 0 4px 20px 0 rgba(0, 0, 0, 0.03);
}

/* 3. Gradient Text Styling */
.gradient-text,
.gradient-text-animated {
  background: linear-gradient(135deg, hsl(262 83% 58%), hsl(199 89% 50%));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: none; /* Removed gold glow */
}

/* 4. Disable old gradients and use soft accents */
.bg-gradient-primary,
.bg-gradient-accent {
  background: linear-gradient(135deg, hsl(262 83% 58%), hsl(262 70% 65%));
}

/* 5. Premium Soft Shadows */
.shadow-glow {
  box-shadow: 0 0 15px rgba(0, 0, 0, 0.05);
}

.shadow-glow-lg {
  box-shadow: 0 0 30px rgba(0, 0, 0, 0.08);
}

.shadow-elevated {
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
}

/* 6. Interactive States */
.hover-lift:hover {
  transform: translateY(-4px);
  box-shadow: 0 15px 35px -5px rgba(0, 0, 0, 0.1);
  @apply bg-white/80 border-white/80 transition-all duration-300;
}

.hover-glow:hover {
  box-shadow: 0 0 25px rgba(139, 92, 246, 0.15); /* Soft purple glow */
}

/* 7. Focus States */
.focus-ring:focus-visible {
  @apply ring-2 ring-offset-2;
  --tw-ring-color: hsl(var(--primary) / 0.5);
  --tw-ring-offset-color: hsl(var(--background));
}

/* 8. Scrollbar - Soft Pastel Thumb */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,0.2); }

::selection { background: hsl(var(--primary) / 0.2); color: hsl(var(--foreground)); }

/* Utilities */
html { scroll-behavior: smooth; }
.skeleton-shimmer { @apply bg-white/50 relative overflow-hidden; }
.skeleton-shimmer::after {
  content: "";
  @apply absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/50 to-transparent animate-[shimmer_1.5s_infinite];
}

.text-balance { text-wrap: balance; }
.text-pretty { text-wrap: pretty; }

/* Typography */
h1, .h1 { @apply scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl text-slate-900; }
h2, .h2 { @apply scroll-m-20 border-b border-slate-200 pb-2 text-3xl font-semibold tracking-tight first:mt-0 text-slate-800; }
h3, .h3 { @apply scroll-m-20 text-2xl font-semibold tracking-tight text-slate-800; }
h4, .h4 { @apply scroll-m-20 text-xl font-semibold tracking-tight text-slate-700; }
h5, .h5 { @apply scroll-m-20 text-lg font-semibold tracking-tight text-slate-700; }
h6, .h6 { @apply scroll-m-20 text-base font-semibold tracking-tight text-slate-700; }

.p { @apply leading-7 [&:not(:first-child)]:mt-6 text-slate-600; }
.lead { @apply text-xl text-slate-600; }
.muted { @apply text-sm text-slate-500; }

code { @apply relative rounded bg-slate-100/80 px-[0.3rem] py-[0.2rem] font-mono text-sm font-semibold text-primary; }
pre { @apply mb-4 mt-6 overflow-x-auto rounded-lg border border-slate-200 bg-white/80 backdrop-blur-sm py-4 shadow-inner; }

.prose-custom {
  @apply prose prose-slate max-w-none;
  @apply prose-headings:text-slate-900;
  @apply prose-p:text-slate-600;
  @apply prose-strong:text-slate-900;
  @apply prose-a:text-primary hover:prose-a:text-primary/80;
}

/* Animations */
.animate-float { animation: float 6s ease-in-out infinite; }
.animate-pulse-glow { animation: pulse-glow 3s ease-in-out infinite; }
@keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }
@keyframes pulse-glow { 0%, 100% { box-shadow: 0 0 10px rgba(139, 92, 246, 0.1); } 50% { box-shadow: 0 0 25px rgba(139, 92, 246, 0.25); } }

@keyframes accordion-down {
  from { height: 0; }
  to { height: var(--radix-accordion-content-height); }
}

@keyframes accordion-up {
  from { height: var(--radix-accordion-content-height); }
  to { height: 0; }
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* ============================================
   SEMANTIC COLOR UTILITY CLASSES
   ============================================ */

/* Text Colors */
.text-success { color: hsl(var(--color-success-text)); }
.text-warning { color: hsl(var(--color-warning-text)); }
.text-error { color: hsl(var(--color-error-text)); }
.text-info { color: hsl(var(--color-info-text)); }

/* Background Colors */
.bg-success { background-color: hsl(var(--color-success-bg)); }
.bg-success-solid { background-color: hsl(var(--color-success-text)); }
.bg-warning { background-color: hsl(var(--color-warning-bg)); }
.bg-warning-solid { background-color: hsl(var(--color-warning-text)); }
.bg-error { background-color: hsl(var(--color-error-bg)); }
.bg-error-solid { background-color: hsl(var(--color-error-text)); }
.bg-info { background-color: hsl(var(--color-info-bg)); }
.bg-info-solid { background-color: hsl(var(--color-info-text)); }

/* Border Colors */
.border-success { border-color: hsl(var(--color-success-text) / 0.3); }
.border-warning { border-color: hsl(var(--color-warning-text) / 0.3); }
.border-error { border-color: hsl(var(--color-error-text) / 0.3); }
.border-info { border-color: hsl(var(--color-info-text) / 0.3); }

/* ============================================
   GLASS MORPHISM - PASTEL TINT
   ============================================ */

.glass-gold { /* Keeping class name for compatibility, changing styles */
  background: linear-gradient(
    135deg,
    rgba(255,255,255, 0.5),
    rgba(255,255,255, 0.2)
  );
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255, 0.4);
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
}

/* Override existing cards to use glassmorphism */
.bg-card {
  @apply bg-white/60 backdrop-blur-xl border border-white/60 shadow-[0_8px_30px_rgb(0,0,0,0.04)];
}

.bg-background {
  @apply bg-transparent; /* Let the body mesh gradient show through */
}

/* ============================================
   ACCESSIBILITY - REDUCED MOTION
   ============================================ */

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* Focus visible for all interactive elements */
:focus-visible {
  outline: 2px solid hsl(var(--primary));
  outline-offset: 2px;
}
